# Copy this file to .env and fill in your values.

# Resend API key (get one at https://resend.com/api-keys)
RESEND_API_KEY=

# The "from" address emails will be sent from. Must be a verified domain/sender in Resend.
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name

# The public URL this app is deployed at (used to build unsubscribe links).
# When testing locally this can be http://localhost:3000
APP_URL=http://localhost:3000

# Port the server listens on (Railway sets this automatically, no need to change).
PORT=3000

# When true, no real emails are sent - everything is just logged. Start here.
DRY_RUN=true

# Optional: set both to require a login for the whole app (recommended before
# you flip DRY_RUN off - without this, anyone with the URL can see/delete
# leads or trigger real sends). Leave both blank for no login.
APP_USERNAME=
APP_PASSWORD=
