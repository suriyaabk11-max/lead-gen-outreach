# Copy this file to .env and fill in your values.

# Postgres connection string (self-hosted, Supabase, Neon, Railway, etc.)
# Example self-hosted: postgresql://user:password@localhost:5432/outreach
DATABASE_URL=

# Searlo API key, only needed for scripts/scrape-leads.js (lead finder).
# Get one at https://searlo.tech
SEARLO_API_KEY=

# Resend API key (get one at https://resend.com/api-keys)
RESEND_API_KEY=

# The "from" address emails will be sent from. Must be a verified domain/sender in Resend.
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name

# The public URL this app is deployed at (used to build unsubscribe links).
# When testing locally this can be http://localhost:3000
APP_URL=http://localhost:3000

# Port the server listens on (Railway sets this automatically, no need to change).
PORT=3000

# When true, no real emails are sent - everything is just logged. Start here.
DRY_RUN=true

# Optional: set both to require a login for the whole app (recommended before
# you flip DRY_RUN off - without this, anyone with the URL can see/delete
# leads or trigger real sends). Leave both blank for no login.
APP_USERNAME=
APP_PASSWORD=

# Optional: Claude API key for the AI personalization endpoints
# (/api/leads/:id/personalize). Leave blank to disable AI features.
ANTHROPIC_API_KEY=

# Optional, deploy-time: set to 1 on small hosts (e.g. Railway Hobby) to skip
# the ~400MB Playwright browser download. Website crawl/audit jobs will fail
# with a clear error until browsers are installed; the email sequencer is
# unaffected.
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
