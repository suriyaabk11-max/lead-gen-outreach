# Copy this file to .env and fill in your values.

# Postgres connection string (self-hosted, Supabase, Neon, Railway, etc.)
# Example self-hosted: postgresql://user:password@localhost:5432/outreach
DATABASE_URL=

# Searlo API key - needed for lead finding: scripts/scrape-leads.js (manual
# CLI run) and the in-app "Lead Finder" tab (scheduled/unattended runs).
# Get one at https://searlo.tech
SEARLO_API_KEY=

# Resend API key (get one at https://resend.com/api-keys)
RESEND_API_KEY=

# The "from" address emails will be sent from. Must be a verified domain/sender in Resend.
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name

# The public URL this app is deployed at (used to build unsubscribe links).
# When testing locally this can be http://localhost:3000
APP_URL=http://localhost:3000

# Port the server listens on (Railway sets this automatically, no need to change).
PORT=3000

# When true, no real emails are sent - everything is just logged. Start here.
DRY_RUN=true

# Optional: set both to require a login for the whole app (recommended before
# you flip DRY_RUN off - without this, anyone with the URL can see/delete
# leads or trigger real sends). Leave both blank for no login.
APP_USERNAME=
APP_PASSWORD=

# Optional: Gemini API key, used only for the {{positive_note}} /
# {{observation}} placeholders in email templates
# (services/openingPersonalizationService.js) - generated once per lead,
# right before their first send, and cached. Uses Gemini (not Claude) for
# its free tier, since this runs on every new lead in a live campaign.
# Get one at https://aistudio.google.com/apikey
# Leave blank to fall back to generic (but not broken) text for those
# placeholders instead of calling the AI.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Claude API key, used only for the separate AI Sales OS endpoints
# (/api/leads/:id/personalize, lead scoring, website audit summaries) -
# unrelated to the Gemini-powered opening lines above.
ANTHROPIC_API_KEY=

# Optional, deploy-time: set to 1 on small hosts to skip the ~400MB
# Playwright browser download. Do NOT set this if you use the Lead Finder
# tab or scripts/scrape-leads.js - both need a real headless browser to
# visit business websites, and will fail with a clear error without it.
# Website crawl/audit jobs need it too; the email sequencer itself is
# unaffected either way.
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
